{
  "name": "@subsquid/squid-sdk",
  "version": "0.0.1",
  "description": "Umbrella package for the Squid SDK: data sources and utilities exposed as subpaths",
  "license": "GPL-3.0-or-later",
  "repository": "git@github.com:subsquid/squid-sdk.git",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "lib",
    "src"
  ],
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "require": "./lib/index.js"
    },
    "./evm-rpc-stream": {
      "types": "./lib/evm-rpc-stream/index.d.ts",
      "import": "./lib/evm-rpc-stream/index.js",
      "require": "./lib/evm-rpc-stream/index.js"
    },
    "./evm-fallback-stream": {
      "types": "./lib/evm-fallback-stream/index.d.ts",
      "import": "./lib/evm-fallback-stream/index.js",
      "require": "./lib/evm-fallback-stream/index.js"
    },
    "./evm-stream": {
      "types": "./lib/evm-stream/index.d.ts",
      "import": "./lib/evm-stream/index.js",
      "require": "./lib/evm-stream/index.js"
    },
    "./solana-stream": {
      "types": "./lib/solana-stream/index.d.ts",
      "import": "./lib/solana-stream/index.js",
      "require": "./lib/solana-stream/index.js"
    },
    "./fuel-stream": {
      "types": "./lib/fuel-stream/index.d.ts",
      "import": "./lib/fuel-stream/index.js",
      "require": "./lib/fuel-stream/index.js"
    },
    "./starknet-stream": {
      "types": "./lib/starknet-stream/index.d.ts",
      "import": "./lib/starknet-stream/index.js",
      "require": "./lib/starknet-stream/index.js"
    },
    "./util-internal": {
      "types": "./lib/util-internal/index.d.ts",
      "import": "./lib/util-internal/index.js",
      "require": "./lib/util-internal/index.js"
    },
    "./util-internal-data-source": {
      "types": "./lib/util-internal-data-source/index.d.ts",
      "import": "./lib/util-internal-data-source/index.js",
      "require": "./lib/util-internal-data-source/index.js"
    },
    "./util-internal-range": {
      "types": "./lib/util-internal-range/index.d.ts",
      "import": "./lib/util-internal-range/index.js",
      "require": "./lib/util-internal-range/index.js"
    },
    "./util-internal-hex": {
      "types": "./lib/util-internal-hex/index.d.ts",
      "import": "./lib/util-internal-hex/index.js",
      "require": "./lib/util-internal-hex/index.js"
    },
    "./util-internal-json": {
      "types": "./lib/util-internal-json/index.d.ts",
      "import": "./lib/util-internal-json/index.js",
      "require": "./lib/util-internal-json/index.js"
    },
    "./util-internal-validation": {
      "types": "./lib/util-internal-validation/index.d.ts",
      "import": "./lib/util-internal-validation/index.js",
      "require": "./lib/util-internal-validation/index.js"
    },
    "./util-internal-processor-tools": {
      "types": "./lib/util-internal-processor-tools/index.d.ts",
      "import": "./lib/util-internal-processor-tools/index.js",
      "require": "./lib/util-internal-processor-tools/index.js"
    },
    "./logger": {
      "types": "./lib/logger/index.d.ts",
      "import": "./lib/logger/index.js",
      "require": "./lib/logger/index.js"
    },
    "./portal-client": {
      "types": "./lib/portal-client/index.d.ts",
      "import": "./lib/portal-client/index.js",
      "require": "./lib/portal-client/index.js"
    },
    "./http-client": {
      "types": "./lib/http-client/index.d.ts",
      "import": "./lib/http-client/index.js",
      "require": "./lib/http-client/index.js"
    },
    "./rpc-client": {
      "types": "./lib/rpc-client/index.d.ts",
      "import": "./lib/rpc-client/index.js",
      "require": "./lib/rpc-client/index.js"
    },
    "./util-timeout": {
      "types": "./lib/util-timeout/index.d.ts",
      "import": "./lib/util-timeout/index.js",
      "require": "./lib/util-timeout/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "evm-rpc-stream": ["./lib/evm-rpc-stream/index.d.ts"],
      "evm-fallback-stream": ["./lib/evm-fallback-stream/index.d.ts"],
      "evm-stream": ["./lib/evm-stream/index.d.ts"],
      "solana-stream": ["./lib/solana-stream/index.d.ts"],
      "fuel-stream": ["./lib/fuel-stream/index.d.ts"],
      "starknet-stream": ["./lib/starknet-stream/index.d.ts"],
      "util-internal": ["./lib/util-internal/index.d.ts"],
      "util-internal-data-source": ["./lib/util-internal-data-source/index.d.ts"],
      "util-internal-range": ["./lib/util-internal-range/index.d.ts"],
      "util-internal-hex": ["./lib/util-internal-hex/index.d.ts"],
      "util-internal-json": ["./lib/util-internal-json/index.d.ts"],
      "util-internal-validation": ["./lib/util-internal-validation/index.d.ts"],
      "util-internal-processor-tools": ["./lib/util-internal-processor-tools/index.d.ts"],
      "logger": ["./lib/logger/index.d.ts"],
      "portal-client": ["./lib/portal-client/index.d.ts"],
      "http-client": ["./lib/http-client/index.d.ts"],
      "rpc-client": ["./lib/rpc-client/index.d.ts"],
      "util-timeout": ["./lib/util-timeout/index.d.ts"]
    }
  },
  "scripts": {
    "build": "rm -rf lib && tsc",
    "test": "vitest --run",
    "test:lfs": "VITEST_LFS=1 vitest --run"
  },
  "dependencies": {
    "@subsquid/evm-normalization": "^0.0.2",
    "@subsquid/evm-rpc": "^0.0.2",
    "@subsquid/evm-stream": "^0.1.1",
    "@subsquid/fuel-stream": "^1.2.0",
    "@subsquid/http-client": "^1.8.1",
    "@subsquid/logger": "^1.6.0",
    "@subsquid/portal-client": "^0.5.2",
    "@subsquid/rpc-client": "^4.15.1",
    "@subsquid/solana-stream": "^1.1.1",
    "@subsquid/starknet-stream": "^1.2.0",
    "@subsquid/util-internal": "^3.3.1",
    "@subsquid/util-internal-data-source": "^0.0.0",
    "@subsquid/util-internal-hex": "^1.2.3",
    "@subsquid/util-internal-json": "^1.2.4",
    "@subsquid/util-internal-processor-tools": "^4.4.0",
    "@subsquid/util-internal-range": "^0.3.0",
    "@subsquid/util-internal-validation": "^0.9.0",
    "@subsquid/util-timeout": "^2.3.2",
    "prom-client": "^14.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "5.5.4",
    "vitest": "4.1.5"
  }
}
