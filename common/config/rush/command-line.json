/**
 * This configuration file defines custom commands for the "rush" command-line.
 * More documentation is available on the Rush website: https://rushjs.io
 */
{
  "$schema": "https://developer.microsoft.com/json-schemas/rush/v5/command-line.schema.json",

  /**
   * Custom "commands" introduce new verbs for the command-line.  To see the help for these
   * example commands, try "rush --help", "rush my-bulk-command --help", or
   * "rush my-global-command --help".
   */
  "commands": [
    {
      "name": "unify-dependencies",
      "commandKind": "global",
      "summary": "Unify dependencies across the project",
      "shellCommand": "node ops/workspace/lib/unify.js"
    },
    {
      "name": "lint",
      "commandKind": "global",
      "summary": "Lint the repository with Biome",
      "autoinstallerName": "lint",
      "shellCommand": "biome lint ."
    },
    {
      "name": "lint:fix",
      "commandKind": "global",
      "summary": "Lint the repository with Biome and apply safe fixes",
      "autoinstallerName": "lint",
      "shellCommand": "biome lint --write ."
    },
    {
      "name": "format",
      "commandKind": "global",
      "summary": "Check formatting with Biome",
      "autoinstallerName": "lint",
      "shellCommand": "biome format ."
    },
    {
      "name": "format:fix",
      "commandKind": "global",
      "summary": "Reformat the repository with Biome",
      "autoinstallerName": "lint",
      "shellCommand": "biome format --write ."
    },
    {
      "name": "biome",
      "commandKind": "global",
      "summary": "Run Biome lint + formatter checks",
      "autoinstallerName": "lint",
      "shellCommand": "biome check ."
    },
    {
      "name": "install-lint",
      "commandKind": "global",
      "summary": "Install the Biome autoinstaller and link it into the root node_modules (runs automatically via postRushInstall)",
      "autoinstallerName": "lint",
      "shellCommand": "node common/scripts/link-biome.js",
      "safeForSimultaneousRushProcesses": true
    },
    {
      "name": "install-vitest",
      "commandKind": "global",
      "summary": "Install the Vitest autoinstaller for the root vitest.config.ts (runs automatically via postRushInstall)",
      "autoinstallerName": "vitest",
      "shellCommand": "node common/scripts/link-vitest.js",
      "safeForSimultaneousRushProcesses": true
    },
    {
      "name": "biome:fix",
      "commandKind": "global",
      "summary": "Run Biome lint + formatter with safe fixes",
      "autoinstallerName": "lint",
      "shellCommand": "biome check --write ."
    },
    {
      "name": "e2e",
      "commandKind": "global",
      "summary": "run e2e test suite",
      "shellCommand": "test/e2e-suite/e2e.sh"
    },
    {
      "name": "test",
      "commandKind": "bulk",
      "summary": "Run unit tests",
      "enableParallelism": false,
      "ignoreMissingScript": true,
      "allowWarningsInSuccessfulBuild": true
    },
    {
      "name": "test:lfs",
      "commandKind": "bulk",
      "summary": "Run LFS test suites (requires git-lfs fixtures)",
      "description": "Executes *.lfs.test.ts suites gated behind opt-in heavy fixtures (git-lfs, network).",
      "enableParallelism": false,
      "ignoreMissingScript": true,
      "allowWarningsInSuccessfulBuild": true
    }
  ],

  /**
   * Custom "parameters" introduce new parameters for specified Rush command-line commands.
   * For example, you might define a "--production" parameter for the "rush build" command.
   */
  "parameters": [
    {
      "parameterKind": "flag",
      "longName": "--update",
      "description": "upgrade dependencies",
      "associatedCommands": ["unify-dependencies"]
    },
    {
      "parameterKind": "flag",
      "longName": "--lower",
      "description": "prefer lower versions",
      "associatedCommands": ["unify-dependencies"]
    },
    {
      "parameterKind": "flag",
      "longName": "--major",
      "description": "allow major upgrades",
      "associatedCommands": ["unify-dependencies"]
    },
    {
      "parameterKind": "flag",
      "longName": "--dry",
      "description": "do not perform real changes",
      "associatedCommands": ["unify-dependencies"]
    }
  ]
}
