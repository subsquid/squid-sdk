# Our temprorary files (e.g. ad-hoc scripts)
**/*.temp.*
**/*.temp

# IDE and tools
.git
.idea
**/*.log

# READMEs and docs
**/*.md

# Ignore Dockerfile, so that we can work on it without full rebuild each time
Dockerfile
docker-bake.hcl
docker-compose.yml
/ops/docker-publish.sh
/ops/docker-publish-dev.sh
/ops/docker-merge.sh
/ops/docker-merge-dev.sh
/ops/pkg-name.js
/ops/pkg-version.js

# CI configs
/.github

# Test projects not needed for Docker images
/test

**/.DS_Store

*.temp
